        <mxCell id="ent-groups" value="student_groups&#xa;────────────────&#xa;PK id: INT&#xa;group_number: INT&#xa;department: VARCHAR(100)&#xa;FK supervisor_id: INT&#xa;max_members, current_members" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;fontStyle=1;" vertex="1" parent="1">
