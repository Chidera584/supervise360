        <mxCell id="ent-supervisors" value="supervisors&#xa;────────────────&#xa;PK id: INT&#xa;FK user_id: INT&#xa;department: VARCHAR(100)&#xa;max_capacity: INT&#xa;current_load: INT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;fontStyle=1;" vertex="1" parent="1">
